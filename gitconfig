[core]
	excludesfile = /Users/axross/.gitignore_global

[init]
	defaultBranch = main

[commit]
	gpgsign = true

[tag]
	gpgSign = true

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[include]
	path = ~/.gitconfig-personal

[includeIf "hasconfig:remote.*.url:git@github.com:parsable/**"]
  path = ~/.gitconfig-parsable
